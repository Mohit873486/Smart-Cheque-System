<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
                  http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="invoice_report"
              pageWidth="595" pageHeight="842"
              columnWidth="535" leftMargin="30" rightMargin="30"
              topMargin="30" bottomMargin="30"
              uuid="b2c3d4e5-f6a7-8901-bcde-f12345678901">

    <parameter name="invoiceNo"  class="java.lang.String"/>
    <parameter name="clientName" class="java.lang.String"/>
    <parameter name="amount"     class="java.lang.String"/>
    <parameter name="issueDate"  class="java.lang.String"/>
    <parameter name="dueDate"    class="java.lang.String"/>
    <parameter name="status"     class="java.lang.String"/>
    <parameter name="notes"      class="java.lang.String"/>

    <background><band splitType="Stretch"/></background>

    <title>
        <band height="782" splitType="Stretch">

            <!-- Header bar -->
            <rectangle>
                <reportElement x="0" y="0" width="535" height="70" backcolor="#1a56db" uuid="r-header"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>

            <!-- Company name -->
            <staticText>
                <reportElement x="14" y="12" width="260" height="28" forecolor="#FFFFFF" uuid="s-company"/>
                <textElement verticalAlignment="Middle">
                    <font size="20" isBold="true"/>
                </textElement>
                <text><![CDATA[💼 ChequePro]]></text>
            </staticText>
            <staticText>
                <reportElement x="14" y="42" width="260" height="16" forecolor="rgba(255,255,255,0.7)" uuid="s-sub"/>
                <textElement><font size="9"/></textElement>
                <text><![CDATA[Professional Cheque & Invoice Manager]]></text>
            </staticText>

            <!-- INVOICE label -->
            <staticText>
                <reportElement x="390" y="12" width="145" height="36" forecolor="#FFFFFF" uuid="s-inv-title"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="26" isBold="true"/>
                </textElement>
                <text><![CDATA[INVOICE]]></text>
            </staticText>

            <!-- Invoice number -->
            <staticText>
                <reportElement x="300" y="50" width="90" height="16" forecolor="#FFFFFF" uuid="s-inv-lbl"/>
                <textElement textAlignment="Right"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Invoice No:]]></text>
            </staticText>
            <textField>
                <reportElement x="394" y="50" width="141" height="16" forecolor="#FFFFFF" uuid="f-invno"/>
                <textElement textAlignment="Right"><font size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$P{invoiceNo}]]></textFieldExpression>
            </textField>

            <!-- Bill To section -->
            <staticText>
                <reportElement x="0" y="90" width="200" height="16" uuid="s-billto"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[BILL TO:]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="108" width="260" height="20" uuid="f-client"/>
                <textElement><font size="13" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$P{clientName}]]></textFieldExpression>
            </textField>

            <!-- Dates (right) -->
            <staticText>
                <reportElement x="360" y="90" width="80" height="16" uuid="s-issue-lbl"/>
                <textElement textAlignment="Right"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Issue Date:]]></text>
            </staticText>
            <textField>
                <reportElement x="444" y="90" width="91" height="16" uuid="f-issue"/>
                <textElement textAlignment="Right"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{issueDate}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="360" y="110" width="80" height="16" uuid="s-due-lbl"/>
                <textElement textAlignment="Right"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Due Date:]]></text>
            </staticText>
            <textField>
                <reportElement x="444" y="110" width="91" height="16" uuid="f-due"/>
                <textElement textAlignment="Right"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{dueDate}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="360" y="130" width="80" height="16" uuid="s-status-lbl"/>
                <textElement textAlignment="Right"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Status:]]></text>
            </staticText>
            <textField>
                <reportElement x="444" y="130" width="91" height="16" uuid="f-status"/>
                <textElement textAlignment="Right"><font size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$P{status}]]></textFieldExpression>
            </textField>

            <!-- Divider -->
            <line>
                <reportElement x="0" y="158" width="535" height="1" uuid="l-div1"/>
                <graphicElement><pen lineWidth="1.5" lineColor="#1a56db"/></graphicElement>
            </line>

            <!-- Table header -->
            <rectangle>
                <reportElement x="0" y="164" width="535" height="28" backcolor="#f1f5f9" uuid="r-th"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="8"   y="170" width="280" height="16" uuid="th-desc"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[DESCRIPTION]]></text>
            </staticText>
            <staticText>
                <reportElement x="445" y="170" width="86" height="16" uuid="th-amount"/>
                <textElement textAlignment="Right"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[AMOUNT (₹)]]></text>
            </staticText>

            <!-- Table row -->
            <line>
                <reportElement x="0" y="192" width="535" height="1" uuid="l-row1"/>
                <graphicElement><pen lineWidth="0.5" lineColor="#e2e8f0"/></graphicElement>
            </line>
            <staticText>
                <reportElement x="8" y="198" width="280" height="20" uuid="td-desc"/>
                <textElement verticalAlignment="Middle"><font size="10"/></textElement>
                <text><![CDATA[Professional Services]]></text>
            </staticText>
            <textField>
                <reportElement x="445" y="198" width="86" height="20" uuid="td-amount"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{amount}]]></textFieldExpression>
            </textField>

            <!-- Totals -->
            <line>
                <reportElement x="0" y="234" width="535" height="1" uuid="l-total"/>
                <graphicElement><pen lineWidth="1.0" lineColor="#e2e8f0"/></graphicElement>
            </line>
            <staticText>
                <reportElement x="360" y="240" width="80" height="20" uuid="s-subtotal-lbl"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="10"/>
                </textElement>
                <text><![CDATA[Sub Total:]]></text>
            </staticText>
            <textField>
                <reportElement x="444" y="240" width="91" height="20" uuid="f-subtotal"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA["₹ " + $P{amount}]]></textFieldExpression>
            </textField>

            <!-- Total row -->
            <rectangle>
                <reportElement x="340" y="264" width="195" height="28" backcolor="#1a56db" uuid="r-total"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="348" y="270" width="90" height="16" forecolor="#FFFFFF" uuid="s-total-lbl"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[TOTAL DUE:]]></text>
            </staticText>
            <textField>
                <reportElement x="444" y="270" width="86" height="16" forecolor="#FFFFFF" uuid="f-total"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="11" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["₹ " + $P{amount}]]></textFieldExpression>
            </textField>

            <!-- Notes -->
            <staticText>
                <reportElement x="0" y="310" width="100" height="16" uuid="s-notes-lbl"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[NOTES:]]></text>
            </staticText>
            <textField isStretchWithOverflow="true">
                <reportElement x="0" y="328" width="535" height="40" uuid="f-notes"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{notes} != null ? $P{notes} : "—"]]></textFieldExpression>
            </textField>

            <!-- Footer -->
            <line>
                <reportElement x="0" y="740" width="535" height="1" uuid="l-footer"/>
                <graphicElement><pen lineWidth="0.5" lineColor="#e2e8f0"/></graphicElement>
            </line>
            <staticText>
                <reportElement x="0" y="748" width="535" height="16" forecolor="#94a3b8" uuid="s-footer"/>
                <textElement textAlignment="Center"><font size="8"/></textElement>
                <text><![CDATA[Thank you for your business! — Generated by ChequePro v2.0]]></text>
            </staticText>

        </band>
    </title>
</jasperReport>