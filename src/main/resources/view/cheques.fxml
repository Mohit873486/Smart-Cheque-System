<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
    styleClass="page-scroll"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.chequeprint.controller.ChequeController">

    <VBox fx:id="rootPane" spacing="22" styleClass="cheque-page"
        maxWidth="Infinity" maxHeight="Infinity">
        <padding>
            <Insets top="26" right="28" bottom="28" left="28" />
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="12">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Cheque Management" styleClass="dashboard-title" />
                <Label text="Create, edit, and print cheque records"
                    styleClass="dashboard-subtitle" />
            </VBox>
            <Button fx:id="btnNewCheque" text="+ New Cheque" styleClass="btn-primary" onAction="#onNewCheque" />
        </HBox>

        <HBox spacing="20" VBox.vgrow="ALWAYS" maxWidth="Infinity" maxHeight="Infinity">
            <VBox spacing="14" styleClass="cheque-list-panel"
                HBox.hgrow="ALWAYS" maxWidth="Infinity" maxHeight="Infinity">
                <HBox spacing="12" alignment="CENTER_LEFT" styleClass="cheque-filter-bar">
                    <HBox spacing="8" alignment="CENTER_LEFT" styleClass="search-shell"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <Label text="⌕" styleClass="search-icon" />
                        <TextField fx:id="searchField" promptText="Search payee name, Cheque..."
                            styleClass="search-input-field" HBox.hgrow="ALWAYS"
                            maxWidth="Infinity" />
                    </HBox>
                    <DatePicker fx:id="filterDate" promptText="Filter by issue date" styleClass="form-date"
                        prefWidth="160" />
                    <ComboBox fx:id="filterStatus" styleClass="filter-combo" promptText="Status"
                        prefWidth="120" />
                    <ComboBox fx:id="filterBank" styleClass="filter-combo" promptText="Bank Name"
                        prefWidth="150" />
                    <Button text="Reset Filters" styleClass="btn-secondary" onAction="#onResetFilters" />


                </HBox>

                <TableView fx:id="chequeTable" styleClass="modern-table"
                    VBox.vgrow="ALWAYS" maxHeight="Infinity">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <placeholder>
                        <Label text="No cheques found. Click '+ New Cheque' to create one."
                            styleClass="table-placeholder" />
                    </placeholder>
                    <columns>
                        <TableColumn fx:id="colChequeNo" text="Cheque" prefWidth="110" minWidth="80" />
                        <TableColumn fx:id="colPayee" text="Payee" prefWidth="160" minWidth="100" />
                        <TableColumn fx:id="colAmount" text="Amount" prefWidth="110" minWidth="80" />
                        <TableColumn fx:id="colBank" text="Bank" prefWidth="130" minWidth="100" />
                        <TableColumn fx:id="colDate" text="Issue Date" prefWidth="100" minWidth="85" />
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="90" minWidth="80" styleClass="align-center" />
                    </columns>
                </TableView>

                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="table-action-footer">
                    <Button fx:id="btnApprove" text="Approve" styleClass="btn-secondary" onAction="#onApprove" />
                    <Button fx:id="btnPrint" text="Print" styleClass="btn-primary" onAction="#onPrint" />
                    <Button fx:id="btnEdit" text="Edit" styleClass="btn-secondary" onAction="#onEdit" />
                    <MenuButton fx:id="btnLifecycle" text="Actions" styleClass="btn-secondary">
                        <items>
                            <MenuItem text="Mark as Deposited" onAction="#onDeposit" />
                            <MenuItem text="Mark as Cleared" onAction="#onClearCheque" />
                            <MenuItem text="Mark as Bounced" onAction="#onBounce" />
                            <MenuItem text="Cancel / Void" onAction="#onCancel" />
                        </items>
                    </MenuButton>
                    <Button fx:id="btnDelete" text="Delete" styleClass="btn-danger-low" onAction="#onDelete" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label text="Double-click a row to edit" styleClass="footer-hint" />
                </HBox>
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
