<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
    styleClass="page-scroll"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.chequeprint.controller.ChequeController">

    <VBox fx:id="rootPane" spacing="22" styleClass="cheque-page"
        maxWidth="Infinity" maxHeight="Infinity">
        <padding>
            <Insets top="26" right="28" bottom="28" left="28" />
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="12">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Cheque Management" styleClass="dashboard-title" />
                <Label text="Create, edit, and print cheque records"
                    styleClass="dashboard-subtitle" />
            </VBox>
            <Button text="+ New Cheque" styleClass="btn-primary" onAction="#onClear" />
        </HBox>

        <HBox spacing="20" VBox.vgrow="ALWAYS" maxWidth="Infinity" maxHeight="Infinity">
            <VBox spacing="14" styleClass="cheque-list-panel"
                HBox.hgrow="ALWAYS" maxWidth="Infinity" maxHeight="Infinity">
                <HBox spacing="12" alignment="CENTER_LEFT" styleClass="cheque-filter-bar">
                    <HBox spacing="8" alignment="CENTER_LEFT" styleClass="search-shell"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <Label text="⌕" styleClass="search-icon" />
                        <TextField fx:id="searchField" promptText="Search cheque #, payee, or bank"
                            styleClass="search-input-field" HBox.hgrow="ALWAYS"
                            maxWidth="Infinity" />
                    </HBox>
                    <ComboBox fx:id="filterStatus" styleClass="filter-combo"
                        prefWidth="150" />
                </HBox>

                <TableView fx:id="chequeTable" styleClass="modern-table"
                    VBox.vgrow="ALWAYS" maxHeight="Infinity">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <placeholder>
                        <Label text="No cheques found. Click '+ New Cheque' to create one."
                            styleClass="table-placeholder" />
                    </placeholder>
                    <columns>
                        <TableColumn fx:id="colChequeNo" text="Cheque #" minWidth="105" />
                        <TableColumn fx:id="colPayee" text="Payee" minWidth="165" />
                        <TableColumn fx:id="colAmount" text="Amount" minWidth="120" />
                        <TableColumn fx:id="colBank" text="Bank" minWidth="120" />
                        <TableColumn fx:id="colDate" text="Issue Date" minWidth="115" />
                        <TableColumn fx:id="colStatus" text="Status" minWidth="100" />
                    </columns>
                </TableView>

                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="table-action-footer">
                    <Button text="Print Selected" styleClass="btn-primary" onAction="#onPrint" />
                    <Button text="Delete" styleClass="btn-danger-low" onAction="#onDelete" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label text="Select a row to edit" styleClass="footer-hint" />
                </HBox>
            </VBox>

            <VBox fx:id="formPanel" spacing="16" styleClass="edit-cheque-card"
                prefWidth="340" minWidth="320" maxWidth="370" maxHeight="Infinity"
                HBox.hgrow="NEVER">
                <Label fx:id="lblFormTitle" text="Edit Cheque"
                    styleClass="form-title-clean" maxWidth="Infinity" />

                <VBox spacing="7">
                    <Label text="Payee Name" styleClass="form-label" />
                    <TextField fx:id="fldPayee" promptText="Enter payee name"
                        styleClass="form-input" maxWidth="Infinity" />
                </VBox>

                <VBox spacing="7">
                    <Label text="Amount" styleClass="form-label" />
                    <HBox alignment="CENTER_LEFT" spacing="0" styleClass="money-input-shell">
                        <Label text="₹" styleClass="money-prefix" />
                        <TextField fx:id="fldAmount" promptText="0.00"
                            styleClass="money-input" HBox.hgrow="ALWAYS"
                            maxWidth="Infinity" />
                    </HBox>
                </VBox>

                <VBox spacing="7">
                    <Label text="Bank" styleClass="form-label" />
                    <ComboBox fx:id="cmbBank" styleClass="form-combo"
                        maxWidth="Infinity" />
                </VBox>

                <VBox spacing="7">
                    <Label text="Issue Date" styleClass="form-label" />
                    <DatePicker fx:id="datePicker" styleClass="form-date"
                        maxWidth="Infinity" />
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <VBox spacing="9">
                    <Button text="Print" styleClass="btn-print-main"
                        maxWidth="Infinity" onAction="#onSaveAndPrint" />
                    <HBox spacing="10">
                        <Button text="Save" styleClass="btn-primary"
                            maxWidth="Infinity" HBox.hgrow="ALWAYS" onAction="#onSave" />
                        <Button text="Clear Form" styleClass="btn-outline-muted"
                            maxWidth="Infinity" HBox.hgrow="ALWAYS" onAction="#onClear" />
                    </HBox>
                </VBox>
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
