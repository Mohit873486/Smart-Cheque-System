<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.chequeprint.controller.MainController"
            maxWidth="Infinity" maxHeight="Infinity">

    <!-- ================= LEFT SIDEBAR ================= -->
    <left>
        <VBox fx:id="sidebar" styleClass="sidebar"
              prefWidth="224" minWidth="224" maxWidth="224">

            <!-- Logo -->
            <VBox styleClass="sidebar-logo" spacing="2">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="💼" styleClass="sidebar-logo-icon" mouseTransparent="true"/>
                    <VBox spacing="0" mouseTransparent="true">
                        <Label text="ChequePro" styleClass="sidebar-logo-text"/>
                        <Label text="Finance Manager" styleClass="sidebar-logo-sub"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Navigation -->
            <VBox spacing="2" VBox.vgrow="ALWAYS" style="-fx-padding: 12 8 8 8;">

                <Label text="MAIN MENU" styleClass="sidebar-section-label"/>

                <HBox styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#onDashboard">
                    <Label text="📊" mouseTransparent="true"/>
                    <Label text="Dashboard" mouseTransparent="true"/>
                </HBox>

                <HBox styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#onCheques">
                    <Label text="📝" mouseTransparent="true"/>
                    <Label text="Cheques" mouseTransparent="true"/>
                </HBox>

                <HBox styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#onInvoices">
                    <Label text="🧾" mouseTransparent="true"/>
                    <Label text="Invoices" mouseTransparent="true"/>
                </HBox>

                <HBox styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#onBanks">
                    <Label text="🏦" mouseTransparent="true"/>
                    <Label text="Banks" mouseTransparent="true"/>
                </HBox>

                <Label text="ACCOUNT" styleClass="sidebar-section-label"/>

                <HBox styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#onProfile">
                    <Label text="👤" mouseTransparent="true"/>
                    <Label text="Profile" mouseTransparent="true"/>
                </HBox>

                <HBox styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#onSettings">
                    <Label text="⚙️" mouseTransparent="true"/>
                    <Label text="Settings" mouseTransparent="true"/>
                </HBox>

                <HBox styleClass="nav-item" spacing="12" alignment="CENTER_LEFT" onMouseClicked="#onSupport">
                    <Label text="💬" mouseTransparent="true"/>
                    <Label text="Support" mouseTransparent="true"/>
                </HBox>

                <Region VBox.vgrow="ALWAYS"/>

                <!-- User -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="AD"/>
                    <VBox>
                        <Label text="Admin User"/>
                        <Label text="Administrator"/>
                    </VBox>
                </HBox>

            </VBox>
        </VBox>
    </left>

    <!-- ================= CENTER CONTENT ================= -->
    <center>

        <VBox maxWidth="Infinity" maxHeight="Infinity">

            <!-- HEADER -->
            <HBox spacing="16" alignment="CENTER_LEFT" styleClass="top-header">
                <Label fx:id="headerTitle" text="Dashboard"/>
                <Region HBox.hgrow="ALWAYS"/>

                <TextField promptText="Search..." prefWidth="200"/>

                <Label text="🔔"/>
                <Label text="AD"/>
            </HBox>

            <!-- MAIN CONTENT -->
            <StackPane fx:id="contentPane"
                       VBox.vgrow="ALWAYS"
                       maxWidth="Infinity"
                       maxHeight="Infinity"
                       style="-fx-background-color:white;"/>
        </VBox>

    </center>

</BorderPane>