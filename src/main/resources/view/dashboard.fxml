<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.chequeprint.controller.DashboardController"
      fx:id="dashboardRoot"
      styleClass="page-root"
      spacing="0">

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color:transparent; -fx-border-width:0;">
        <VBox spacing="24" style="-fx-padding: 28 28 28 28;">

            <!-- Page Header -->
            <VBox spacing="4">
                <Label fx:id="lblWelcome" text="Good Morning 👋" styleClass="page-title"/>
                <Label fx:id="lblSubtitle" text="Here's what's happening with your finances today."
                       styleClass="page-subtitle"/>
            </VBox>

            <!-- ── Stat Cards Row ── -->
            <HBox fx:id="statsRow" spacing="16">
                <!-- Total Cheques -->
                <VBox fx:id="cardTotal" styleClass="stat-card" spacing="12" HBox.hgrow="ALWAYS">
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label text="📄" styleClass="stat-icon stat-icon-blue"/>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Total Cheques" styleClass="stat-label"/>
                            <Label fx:id="lblTotalCheques" text="0" styleClass="stat-value"/>
                            <Label text="All time records" styleClass="stat-sub"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Printed -->
                <VBox fx:id="cardPrinted" styleClass="stat-card" spacing="12" HBox.hgrow="ALWAYS">
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label text="✅" styleClass="stat-icon stat-icon-green"/>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Printed" styleClass="stat-label"/>
                            <Label fx:id="lblPrinted" text="0" styleClass="stat-value"/>
                            <Label text="Successfully printed" styleClass="stat-sub"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Pending -->
                <VBox fx:id="cardPending" styleClass="stat-card" spacing="12" HBox.hgrow="ALWAYS">
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label text="⏳" styleClass="stat-icon stat-icon-amber"/>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Pending" styleClass="stat-label"/>
                            <Label fx:id="lblPending" text="0" styleClass="stat-value"/>
                            <Label text="Awaiting action" styleClass="stat-sub"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Monthly Amount -->
                <VBox fx:id="cardAmount" styleClass="stat-card" spacing="12" HBox.hgrow="ALWAYS">
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label text="💰" styleClass="stat-icon stat-icon-purple"/>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="This Month" styleClass="stat-label"/>
                            <Label fx:id="lblMonthlyAmount" text="₹0" styleClass="stat-value"/>
                            <Label text="Total amount issued" styleClass="stat-sub"/>
                        </VBox>
                    </HBox>
                </VBox>
            </HBox>

            <!-- ── Quick Actions Row ── -->
            <VBox spacing="12">
                <Label text="Quick Actions" styleClass="section-title"/>
                <HBox spacing="16">
                    <VBox styleClass="quick-card" spacing="8" HBox.hgrow="ALWAYS"
                          alignment="CENTER" onMouseClicked="#onViewAllCheques">
                        <Label text="📝" styleClass="quick-icon"/>
                        <Label text="New Cheque" styleClass="quick-label"/>
                        <Label text="Create and print a cheque" styleClass="quick-sub"/>
                    </VBox>
                    <VBox styleClass="quick-card" spacing="8" HBox.hgrow="ALWAYS"
                          alignment="CENTER" onMouseClicked="#onViewAllInvoices">
                        <Label text="🧾" styleClass="quick-icon"/>
                        <Label text="New Invoice" styleClass="quick-label"/>
                        <Label text="Generate a client invoice" styleClass="quick-sub"/>
                    </VBox>
                    <VBox styleClass="quick-card" spacing="8" HBox.hgrow="ALWAYS"
                          alignment="CENTER" onMouseClicked="#onViewAllCheques">
                        <Label text="🖨️" styleClass="quick-icon"/>
                        <Label text="Print Queue" styleClass="quick-label"/>
                        <Label text="View pending prints" styleClass="quick-sub"/>
                    </VBox>
                    <VBox styleClass="quick-card" spacing="8" HBox.hgrow="ALWAYS"
                          alignment="CENTER" onMouseClicked="#onViewAllInvoices">
                        <Label text="📊" styleClass="quick-icon"/>
                        <Label text="Reports" styleClass="quick-label"/>
                        <Label text="View financial reports" styleClass="quick-sub"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ── Recent Section ── -->
            <VBox fx:id="recentSection" styleClass="card" spacing="14">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Recent Activity" styleClass="section-title" HBox.hgrow="ALWAYS"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="View All Cheques →" styleClass="link-btn" onAction="#onViewAllCheques"/>
                </HBox>

                <!-- Recent items placeholder -->
                <VBox spacing="0" styleClass="data-table" style="-fx-background-radius:12px; -fx-border-radius:12px;">
                    <HBox style="-fx-background-color:#f8fafc; -fx-padding:10 16 10 16; -fx-border-color:transparent transparent #e2e8f0 transparent; -fx-border-width:0 0 1 0;">
                        <Label text="CHEQUE NO" style="-fx-font-size:11px; -fx-font-weight:bold; -fx-text-fill:#64748b;" prefWidth="120"/>
                        <Label text="PAYEE" style="-fx-font-size:11px; -fx-font-weight:bold; -fx-text-fill:#64748b;" prefWidth="200"/>
                        <Label text="AMOUNT" style="-fx-font-size:11px; -fx-font-weight:bold; -fx-text-fill:#64748b;" prefWidth="130"/>
                        <Label text="BANK" style="-fx-font-size:11px; -fx-font-weight:bold; -fx-text-fill:#64748b;" prefWidth="120"/>
                        <Label text="STATUS" style="-fx-font-size:11px; -fx-font-weight:bold; -fx-text-fill:#64748b;"/>
                    </HBox>
                    <Label text="No recent activity. Create your first cheque to get started."
                           styleClass="table-placeholder"
                           style="-fx-padding:30 16 30 16; -fx-alignment:center;"
                           maxWidth="Infinity" alignment="CENTER"/>
                </VBox>

                <HBox alignment="CENTER_RIGHT">
                    <Button text="View All Invoices →" styleClass="link-btn" onAction="#onViewAllInvoices"/>
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>