<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
  FIXED settings.fxml
  ====================
  PROBLEMS IN ORIGINAL:
  1. ScrollPane had fitToHeight="false" which is actually correct for a
     scrollable page — this was already right.
  2. Root VBox was missing prefWidth/prefHeight binding to scene size.
     maxWidth/maxHeight="Infinity" was present which is good.
  3. Inner content VBox had no maxWidth="Infinity" so it could not fill the
     ScrollPane viewport horizontally even with fitToWidth="true".
  4. Setting rows had inline border styles that used a non-standard shorthand
     that doesn't always work in JavaFX CSS. Replaced with styleClass.

  FIXES:
  1. Root VBox and ScrollPane: maxWidth/maxHeight="Infinity" confirmed.
  2. Inner content VBox: maxWidth="Infinity" added.
  3. ScrollPane: fitToWidth="true", fitToHeight="false" (correct pattern).
  4. Setting rows use styleClass="setting-row" cleanly.
-->
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.chequeprint.controller.SettingsController"
      fx:id="rootPane"
      styleClass="page-root"
      maxWidth="Infinity"
      maxHeight="Infinity"
      spacing="0">

    <ScrollPane fitToWidth="true"
                fitToHeight="false"
                VBox.vgrow="ALWAYS"
                style="-fx-background-color:transparent; -fx-border-width:0;">

        <VBox spacing="24" maxWidth="Infinity"
              style="-fx-padding: 28 28 28 28; -fx-background-color:#f1f5f9;">

            <!-- Page Header -->
            <VBox spacing="4">
                <Label text="⚙️ Settings" styleClass="page-title"/>
                <Label text="Configure application preferences and defaults"
                       styleClass="page-subtitle"/>
            </VBox>

            <!-- Print Settings Card -->
            <VBox styleClass="card" spacing="0" maxWidth="Infinity">
                <Label text="🖨️  Print Settings" styleClass="section-title"
                       style="-fx-padding: 0 0 14 0;
                              -fx-border-color: transparent transparent #e2e8f0 transparent;
                              -fx-border-width: 0 0 1 0;"/>

                <HBox styleClass="setting-row" alignment="CENTER_LEFT" spacing="16">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Default Bank"                              styleClass="setting-name"/>
                        <Label text="Pre-select this bank when creating cheques" styleClass="setting-desc"/>
                    </VBox>
                    <ComboBox fx:id="cmbDefaultBank" styleClass="form-combo" prefWidth="160"/>
                </HBox>
                <Separator/>

                <HBox styleClass="setting-row" alignment="CENTER_LEFT" spacing="16">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Paper Size"                      styleClass="setting-name"/>
                        <Label text="Default paper size for printing"  styleClass="setting-desc"/>
                    </VBox>
                    <ComboBox fx:id="cmbPaperSize" styleClass="form-combo" prefWidth="160"/>
                </HBox>
                <Separator/>

                <HBox styleClass="setting-row" alignment="CENTER_LEFT" spacing="16">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Printer Name"              styleClass="setting-name"/>
                        <Label text="Name of the printer to use" styleClass="setting-desc"/>
                    </VBox>
                    <TextField fx:id="fldPrinterName" styleClass="form-input" prefWidth="200"/>
                </HBox>
            </VBox>

            <!-- App Preferences Card -->
            <VBox styleClass="card" spacing="0" maxWidth="Infinity">
                <Label text="🔧  App Preferences" styleClass="section-title"
                       style="-fx-padding: 0 0 14 0;
                              -fx-border-color: transparent transparent #e2e8f0 transparent;
                              -fx-border-width: 0 0 1 0;"/>

                <HBox styleClass="setting-row" alignment="CENTER_LEFT" spacing="16">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Auto-save"                   styleClass="setting-name"/>
                        <Label text="Automatically save changes"  styleClass="setting-desc"/>
                    </VBox>
                    <CheckBox fx:id="chkAutoSave"/>
                </HBox>
                <Separator/>

                <HBox styleClass="setting-row" alignment="CENTER_LEFT" spacing="16">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Notifications"                 styleClass="setting-name"/>
                        <Label text="Show desktop notifications"    styleClass="setting-desc"/>
                    </VBox>
                    <CheckBox fx:id="chkNotifications"/>
                </HBox>
            </VBox>

            <!-- About Card -->
            <VBox styleClass="card" spacing="12" maxWidth="Infinity">
                <Label text="ℹ️  About ChequePro" styleClass="section-title"/>
                <HBox spacing="12">
                    <Label text="Version:" style="-fx-text-fill:#64748b; -fx-font-size:13px;"/>
                    <Label text="2.0.0"    style="-fx-font-weight:bold; -fx-text-fill:#1e293b;"/>
                </HBox>
                <HBox spacing="12">
                    <Label text="Build:"   style="-fx-text-fill:#64748b; -fx-font-size:13px;"/>
                    <Label text="JavaFX 17 + MySQL + JasperReports"
                           style="-fx-font-weight:bold; -fx-text-fill:#1e293b;"/>
                </HBox>
            </VBox>

            <HBox>
                <Button text="💾  Save Settings" styleClass="btn-primary"
                        onAction="#onSaveSettings"/>
            </HBox>

        </VBox>
    </ScrollPane>
</VBox>
