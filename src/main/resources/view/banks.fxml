<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER" vbarPolicy="NEVER"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.chequeprint.controller.BankController"
            style="-fx-background-color: #f1f5f9; -fx-background: #f1f5f9; -fx-padding: 0; -fx-border-width: 0;">
    
    <content>
        <BorderPane maxWidth="Infinity" maxHeight="Infinity" style="-fx-background-color: #f1f5f9;">
            
            <!-- LEFT SIDEBAR: Drawer (Bank settings & Layers) -->
            <left>
                <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: #f8fafc; -fx-border-color: transparent #cbd5e1 transparent transparent; -fx-border-width: 0 1 0 0;"
                            prefWidth="310" minWidth="310" maxWidth="310" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
                    <VBox spacing="14" style="-fx-padding: 14;">
                        
                        <!-- Bank Info Card -->
                        <VBox spacing="10" styleClass="card">
                            <HBox alignment="CENTER_LEFT" spacing="6">
                                <Label fx:id="lblFormTitle" text="Add New Bank Template" styleClass="form-title" style="-fx-font-size: 13px;" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="btnNewBank" text="+ Add" styleClass="btn-primary" onAction="#onClear" visible="false" managed="false" />
                            </HBox>
                            
                            <GridPane hgap="6" vgap="6">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="38" />
                                    <ColumnConstraints percentWidth="62" />
                                </columnConstraints>
                                
                                <Label text="Bank Name" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                                <ComboBox fx:id="fldBankName" editable="true" promptText="Select bank" styleClass="form-combo" maxWidth="Infinity" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                                
                                <Label text="Bank Code" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                                <TextField fx:id="fldBankCode" promptText="e.g. AXIS" styleClass="form-input" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                                
                                <Label text="Cheque Size" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                                <ComboBox fx:id="cmbChequeSize" styleClass="form-combo" maxWidth="Infinity" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                                
                                <Label text="Size Unit" styleClass="form-label" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                                <ComboBox fx:id="cmbChequeSizeUnit" styleClass="form-combo" maxWidth="Infinity" GridPane.rowIndex="3" GridPane.columnIndex="1" />
                                
                                <Label fx:id="lblCustomWidth" text="Custom W" styleClass="form-label" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                                <TextField fx:id="fldCustomWidth" promptText="8.5" styleClass="form-input" GridPane.rowIndex="4" GridPane.columnIndex="1" />
                                
                                <Label fx:id="lblCustomHeight" text="Custom H" styleClass="form-label" GridPane.rowIndex="5" GridPane.columnIndex="0" />
                                <TextField fx:id="fldCustomHeight" promptText="3.66" styleClass="form-input" GridPane.rowIndex="5" GridPane.columnIndex="1" />
                                
                                <Label text="MICR Line" styleClass="form-label" GridPane.rowIndex="6" GridPane.columnIndex="0" />
                                <CheckBox fx:id="chkMicr" selected="true" GridPane.rowIndex="6" GridPane.columnIndex="1" />
                            </GridPane>
                            
                            <!-- Form Actions -->
                            <VBox spacing="6" style="-fx-padding: 4 0 0 0;">
                                <Button fx:id="btnSave" text="Save Bank Template" styleClass="btn-primary" onAction="#onSave" maxWidth="Infinity" style="-fx-cursor: hand;" />
                                <HBox spacing="6">
                                    <Button fx:id="btnClear" text="Clear Form" styleClass="btn-secondary" onAction="#onClear" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-cursor: hand;" />
                                    <Button fx:id="btnDelete" text="Delete" styleClass="btn-danger" onAction="#onDelete" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-cursor: hand;" />
                                </HBox>
                                <Button text="Export Template PDF" styleClass="btn-secondary" onAction="#onExportPdf" maxWidth="Infinity" style="-fx-cursor: hand;" />
                            </VBox>
                            
                            <Separator style="-fx-padding: 2 0;" />
                            
                            <!-- Layout Actions -->
                            <VBox spacing="6">
                                <Label text="Layout Data" style="-fx-font-weight: bold; -fx-text-fill: #64748b; -fx-font-size: 11px;" />
                                <HBox spacing="6">
                                    <Button text="Import JSON" styleClass="btn-secondary" onAction="#onImportJson" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-cursor: hand; -fx-font-size: 11.5px;" />
                                    <Button text="Export JSON" styleClass="btn-secondary" onAction="#onExportJson" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-cursor: hand; -fx-font-size: 11.5px;" />
                                </HBox>
                                <Button text="Reset to Default Layout" styleClass="btn-secondary" onAction="#onResetDefaultLayout" maxWidth="Infinity" style="-fx-cursor: hand; -fx-font-size: 11.5px; -fx-text-fill: #ef4444;" />
                            </VBox>
                        </VBox>
                        
                        <!-- Layers Panel (Canvas Elements) -->
                        <VBox spacing="8" styleClass="card">
                            <Label text="Canvas Layers" style="-fx-font-weight: bold; -fx-text-fill: #334155; -fx-font-size: 13px;" />
                            
                            <VBox fx:id="layersContainer" spacing="5">
                                <Button fx:id="layerDate" text="📅 Date Field" styleClass="btn-secondary" onAction="#onSelectLayerDate" maxWidth="Infinity" style="-fx-cursor: hand; -fx-alignment: center-left; -fx-padding: 6 10; -fx-font-size: 11.5px;" />
                                <Button fx:id="layerPayee" text="📝 Payee Line" styleClass="btn-secondary" onAction="#onSelectLayerPayee" maxWidth="Infinity" style="-fx-cursor: hand; -fx-alignment: center-left; -fx-padding: 6 10; -fx-font-size: 11.5px;" />
                                <Button fx:id="layerAmountNumber" text="💰 Amount Number" styleClass="btn-secondary" onAction="#onSelectLayerAmountNumber" maxWidth="Infinity" style="-fx-cursor: hand; -fx-alignment: center-left; -fx-padding: 6 10; -fx-font-size: 11.5px;" />
                                <Button fx:id="layerAmountWords" text="🔤 Amount Words" styleClass="btn-secondary" onAction="#onSelectLayerAmountWords" maxWidth="Infinity" style="-fx-cursor: hand; -fx-alignment: center-left; -fx-padding: 6 10; -fx-font-size: 11.5px;" />
                                <Button fx:id="layerSignature" text="✍️ Signature Area" styleClass="btn-secondary" onAction="#onSelectLayerSignature" maxWidth="Infinity" style="-fx-cursor: hand; -fx-alignment: center-left; -fx-padding: 6 10; -fx-font-size: 11.5px;" />
                                <Button fx:id="layerBankLogo" text="🏢 Bank Logo" styleClass="btn-secondary" onAction="#onSelectLayerBankLogo" maxWidth="Infinity" style="-fx-cursor: hand; -fx-alignment: center-left; -fx-padding: 6 10; -fx-font-size: 11.5px;" />
                                <Button fx:id="layerMicr" text="📊 MICR Line" styleClass="btn-secondary" onAction="#onSelectLayerMicr" maxWidth="Infinity" style="-fx-cursor: hand; -fx-alignment: center-left; -fx-padding: 6 10; -fx-font-size: 11.5px;" />
                            </VBox>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </left>
            
            <!-- CENTER: Canvas Workspace area -->
            <center>
                <VBox spacing="10" style="-fx-background-color: #cbd5e1; -fx-padding: 12;" VBox.vgrow="ALWAYS">
                    
                    <!-- Canvas Controls & HUD Bar -->
                    <HBox spacing="10" alignment="CENTER_LEFT" 
                          style="-fx-background-color: #f1f5f9; -fx-padding: 8 12; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 4, 0, 0, 1);">
                        
                        <!-- Cheque size indicator -->
                        <Label fx:id="lblPreviewSize" text="Size: 8.00 x 3.66 in" minWidth="-Infinity" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 11px;" />
                        
                        <Separator orientation="VERTICAL" style="-fx-opacity: 0.5;" />
                        
                        <!-- View toggles -->
                        <CheckBox fx:id="chkShowGrid" text="Grid" selected="true" onAction="#onToggleGrid" minWidth="-Infinity" style="-fx-font-size: 11px; -fx-cursor: hand;" />
                        <CheckBox fx:id="chkSnapGrid" text="Snap" selected="true" minWidth="-Infinity" style="-fx-font-size: 11px; -fx-cursor: hand;" />
                        <CheckBox fx:id="chkShowRulers" text="Rulers" selected="true" onAction="#onToggleRulers" minWidth="-Infinity" style="-fx-font-size: 11px; -fx-cursor: hand;" />
                        
                        <Separator orientation="VERTICAL" style="-fx-opacity: 0.5;" />
                        
                        <!-- Canvas Zoom Controls -->
                        <HBox spacing="4" alignment="CENTER" minWidth="-Infinity">
                            <Button text="-" onAction="#onZoomOut" styleClass="btn-secondary" style="-fx-padding: 1 6; -fx-font-size: 10px; -fx-font-weight: bold; -fx-cursor: hand;" />
                            <Label fx:id="lblZoom" text="100%" minWidth="-Infinity" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-min-width: 35px; -fx-alignment: center;" />
                            <Button text="+" onAction="#onZoomIn" styleClass="btn-secondary" style="-fx-padding: 1 6; -fx-font-size: 10px; -fx-font-weight: bold; -fx-cursor: hand;" />
                        </HBox>
                        
                        <Region HBox.hgrow="ALWAYS" />
                        
                        <!-- Coordinates HUD label -->
                        <Label fx:id="lblCoordinatesHUD" text="Select a canvas element" minWidth="-Infinity" style="-fx-text-fill: #2563eb; -fx-font-weight: bold; -fx-font-size: 11.5px;" />
                    </HBox>
                    
                    <!-- Canvas stack -->
                    <StackPane fx:id="previewViewport" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: #94a3b8; -fx-border-color: #cbd5e1; -fx-border-width: 1; -fx-background-radius: 8; -fx-border-radius: 8;">
                        <ScrollPane fx:id="canvasScrollPane" fitToWidth="false" fitToHeight="false" 
                                    style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;"
                                    hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED">
                            <StackPane style="-fx-padding: 20;">
                                <Pane fx:id="chequePreviewPane" prefWidth="720" prefHeight="300"
                                      style="-fx-background-color: white; -fx-border-color: #475569; -fx-border-width: 1; -fx-background-radius: 6; -fx-border-radius: 6; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.2), 15, 0, 0, 5);" />
                            </StackPane>
                        </ScrollPane>
                    </StackPane>
                </VBox>
            </center>
            
            <!-- RIGHT SIDEBAR: Inspector (Selected field details & alignments) -->
            <right>
                <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: #f8fafc; -fx-border-color: transparent transparent transparent #cbd5e1; -fx-border-width: 0 0 0 1;"
                            prefWidth="260" minWidth="260" maxWidth="260" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
                    <VBox spacing="14" style="-fx-padding: 14;">
                        
                        <!-- Selected Field Properties Card -->
                        <VBox spacing="10" styleClass="card">
                            <Label text="Field Properties (mm)" styleClass="form-title" style="-fx-font-size: 13px;" />
                            
                            <VBox spacing="8">
                                <VBox spacing="2">
                                    <Label text="Active Layer:" styleClass="form-label" style="-fx-text-fill: #64748b; -fx-font-size: 11px;" />
                                    <Label fx:id="lblActiveLayerName" text="None" style="-fx-font-weight: bold; -fx-text-fill: #2563eb; -fx-font-size: 13px;" wrapText="true" />
                                </VBox>
                                
                                <Separator />
                                
                                <GridPane hgap="6" vgap="6" fx:id="inspectorGrid" disable="true">
                                    <columnConstraints>
                                        <ColumnConstraints percentWidth="42" />
                                        <ColumnConstraints percentWidth="58" />
                                    </columnConstraints>
                                    
                                    <Label text="Left (X)" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                                    <TextField fx:id="fldAdjustLeft" promptText="mm" styleClass="form-input" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                                    
                                    <Label text="Top (Y)" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                                    <TextField fx:id="fldAdjustTop" promptText="mm" styleClass="form-input" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                                    
                                    <Label text="Width" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                                    <TextField fx:id="fldAdjustWidth" promptText="mm" styleClass="form-input" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                                    
                                    <Label text="Height" styleClass="form-label" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                                    <TextField fx:id="fldAdjustHeight" promptText="mm" styleClass="form-input" GridPane.rowIndex="3" GridPane.columnIndex="1" />
                                </GridPane>
                                
                                <ComboBox fx:id="cmbAdjustField" visible="false" managed="false" />
                                
                                <Button text="Apply Changes" onAction="#onApplyFieldAdjustment" maxWidth="Infinity" styleClass="btn-primary" style="-fx-cursor: hand;" />
                            </VBox>
                        </VBox>
                        
                        <!-- Alignments & Actions Panel -->
                        <VBox spacing="10" styleClass="card">
                            <Label text="Canva Alignments" style="-fx-font-weight: bold; -fx-text-fill: #334155; -fx-font-size: 13px;" />
                            
                            <VBox spacing="8" alignment="CENTER" fx:id="alignmentPanel" disable="true">
                                <Label text="Align to Canvas Edges:" style="-fx-text-fill: #64748b; -fx-font-size: 11px;" />
                                <GridPane hgap="4" vgap="4">
                                    <columnConstraints>
                                        <ColumnConstraints percentWidth="33.3" />
                                        <ColumnConstraints percentWidth="33.3" />
                                        <ColumnConstraints percentWidth="33.3" />
                                    </columnConstraints>
                                    
                                    <Button text="Left" onAction="#onAlignLeft" maxWidth="Infinity" styleClass="btn-secondary" style="-fx-font-size: 10px; -fx-padding: 5 2; -fx-cursor: hand;" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                                    <Button text="Center H" onAction="#onCenterHorizontal" maxWidth="Infinity" styleClass="btn-secondary" style="-fx-font-size: 10px; -fx-padding: 5 2; -fx-cursor: hand;" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                                    <Button text="Right" onAction="#onAlignRight" maxWidth="Infinity" styleClass="btn-secondary" style="-fx-font-size: 10px; -fx-padding: 5 2; -fx-cursor: hand;" GridPane.rowIndex="0" GridPane.columnIndex="2" />
                                    
                                    <Button text="Top" onAction="#onAlignTop" maxWidth="Infinity" styleClass="btn-secondary" style="-fx-font-size: 10px; -fx-padding: 5 2; -fx-cursor: hand;" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                                    <Button text="Center V" onAction="#onCenterVertical" maxWidth="Infinity" styleClass="btn-secondary" style="-fx-font-size: 10px; -fx-padding: 5 2; -fx-cursor: hand;" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                                    <Button text="Bottom" onAction="#onAlignBottom" maxWidth="Infinity" styleClass="btn-secondary" style="-fx-font-size: 10px; -fx-padding: 5 2; -fx-cursor: hand;" GridPane.rowIndex="1" GridPane.columnIndex="2" />
                                </GridPane>
                                
                                <Separator style="-fx-padding: 2 0;" />
                                
                                <Label text="Quick Size Presets:" style="-fx-text-fill: #64748b; -fx-font-size: 11px;" />
                                <HBox spacing="4">
                                    <Button text="Small" onAction="#onPresetSmall" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="btn-secondary" style="-fx-font-size: 10px; -fx-padding: 5 0; -fx-cursor: hand;" />
                                    <Button text="Medium" onAction="#onPresetMedium" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="btn-secondary" style="-fx-font-size: 10px; -fx-padding: 5 0; -fx-cursor: hand;" />
                                    <Button text="Large" onAction="#onPresetLarge" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="btn-secondary" style="-fx-font-size: 10px; -fx-padding: 5 0; -fx-cursor: hand;" />
                                </HBox>
                                <Button text="Full Width" onAction="#onPresetFullWidth" maxWidth="Infinity" styleClass="btn-secondary" style="-fx-font-size: 10px; -fx-padding: 5 0; -fx-cursor: hand;" />
                            </VBox>
                        </VBox>
                        
                    </VBox>
                </ScrollPane>
            </right>
            
        </BorderPane>
    </content>
</ScrollPane>
