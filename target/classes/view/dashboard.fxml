<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.chequeprint.controller.DashboardController"
    fx:id="dashboardRoot"
    styleClass="dashboard-root"
    maxWidth="Infinity" maxHeight="Infinity">

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            styleClass="page-scroll">
            <content>
                <VBox spacing="24" styleClass="dashboard-page"
                    maxWidth="Infinity" maxHeight="Infinity">
                    <padding>
                        <Insets top="28" right="32" bottom="32" left="32" />
                    </padding>

                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label fx:id="lblWelcome" text="Welcome, Mohit"
                                styleClass="dashboard-title" />
                            <Label fx:id="lblSubtitle" text="Finance Dashboard"
                                styleClass="dashboard-subtitle" />
                        </VBox>
                        <Button fx:id="btnNewCheque" text="+ New Cheque"
                            onAction="#onNewCheque" styleClass="btn-primary" />
                    </HBox>

                    <HBox fx:id="statsRow" spacing="16">
                        <VBox fx:id="cardTotal" spacing="10" alignment="TOP_LEFT"
                            styleClass="kpi-card" HBox.hgrow="ALWAYS">
                            <Label text="Total Cheques" styleClass="kpi-label" />
                            <Label fx:id="lblTotalCheques" text="48" styleClass="kpi-value" />
                            <Label fx:id="lblChequesChange" text="Active cheque records"
                                styleClass="kpi-note" />
                        </VBox>

                        <VBox fx:id="cardPending" spacing="10" alignment="TOP_LEFT"
                            styleClass="kpi-card-warning" HBox.hgrow="ALWAYS">
                            <Label text="Pending Clearance" styleClass="kpi-label" />
                            <Label fx:id="lblPendingCheques" text="0"
                                styleClass="kpi-value-warning" />
                            <Label text="Awaiting bank clearance" styleClass="kpi-note" />
                        </VBox>

                        <VBox spacing="10" alignment="TOP_LEFT"
                            styleClass="kpi-card" HBox.hgrow="ALWAYS">
                            <Label text="Total Invoices" styleClass="kpi-label" />
                            <Label fx:id="lblTotalInvoices" text="12" styleClass="kpi-value" />
                            <Label fx:id="lblInvoicesChange" text="Created this period"
                                styleClass="kpi-note" />
                        </VBox>

                        <VBox fx:id="cardAmount" spacing="10" alignment="TOP_LEFT"
                            styleClass="kpi-card-value" HBox.hgrow="ALWAYS">
                            <Label text="Total Value" styleClass="kpi-label" />
                            <Label fx:id="lblTotalAmount" text="₹11,908,124"
                                styleClass="kpi-value-money" />
                            <Label text="Across all transactions" styleClass="kpi-note" />
                        </VBox>
                    </HBox>

                    <HBox spacing="18" alignment="TOP_LEFT" fillHeight="false" VBox.vgrow="ALWAYS">
                        <VBox spacing="16" styleClass="dashboard-card"
                            HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <HBox alignment="CENTER_LEFT">
                                <Label text="Recent Cheques" styleClass="panel-title" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="btnViewAllCheques" text="View All"
                                    onAction="#onViewAllCheques" styleClass="btn-link" />
                            </HBox>

                            <TableView fx:id="tblRecentCheques" styleClass="modern-table"
                                prefHeight="360" VBox.vgrow="ALWAYS">
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                </columnResizePolicy>
                                <columns>
                                    <TableColumn fx:id="colChequeNo" text="Cheque #" minWidth="95" />
                                    <TableColumn fx:id="colPayee" text="Payee" minWidth="160" />
                                    <TableColumn fx:id="colAmount" text="Amount" minWidth="120" />
                                    <TableColumn fx:id="colBank" text="Bank" minWidth="120" />
                                    <TableColumn fx:id="colStatus" text="Status" minWidth="105" />
                                </columns>
                                <placeholder>
                                    <Label text="No recent cheques to display."
                                        styleClass="table-placeholder" />
                                </placeholder>
                            </TableView>
                        </VBox>

                        <VBox spacing="14" styleClass="status-widget"
                            prefWidth="310" minWidth="300" maxWidth="330"
                            prefHeight="300" maxHeight="-Infinity">
                            <Label text="Cheque Status Distribution" styleClass="panel-title" />

                            <VBox spacing="6">
                                <HBox alignment="CENTER_LEFT">
                                    <Label text="Draft" styleClass="status-widget-label" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="lblDraftCount" text="0" styleClass="status-widget-count" />
                                </HBox>
                                <ProgressBar fx:id="pbDraft" progress="0" maxWidth="Infinity"
                                    styleClass="progress-draft" />
                            </VBox>

                            <VBox spacing="6">
                                <HBox alignment="CENTER_LEFT">
                                    <Label text="Pending" styleClass="status-widget-label" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="lblPendingCount" text="0" styleClass="pending-text" />
                                </HBox>
                                <ProgressBar fx:id="pbPending" progress="0" maxWidth="Infinity"
                                    styleClass="progress-pending" />
                            </VBox>

                            <VBox spacing="6">
                                <HBox alignment="CENTER_LEFT">
                                    <Label text="Printed" styleClass="status-widget-label" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="lblPrintedCount" text="0" styleClass="printed-text" />
                                </HBox>
                                <ProgressBar fx:id="pbPrinted" progress="0" maxWidth="Infinity"
                                    styleClass="progress-printed" />
                            </VBox>

                            <VBox spacing="6">
                                <HBox alignment="CENTER_LEFT">
                                    <Label text="Cleared" styleClass="status-widget-label" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="lblClearedCount" text="0" styleClass="cleared-text" />
                                </HBox>
                                <ProgressBar fx:id="pbCleared" progress="0" maxWidth="Infinity"
                                    styleClass="progress-cleared" />
                            </VBox>
                        </VBox>
                    </HBox>

                    <VBox spacing="16" styleClass="dashboard-card">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Recent Invoices" styleClass="panel-title" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button fx:id="btnViewAllInvoices" text="View All"
                                onAction="#onViewAllInvoices" styleClass="btn-link" />
                        </HBox>

                        <TableView fx:id="tblRecentInvoices" styleClass="modern-table"
                            prefHeight="210">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colInvoiceNo" text="Invoice #" minWidth="120" />
                                <TableColumn fx:id="colInvoiceClient" text="Client" minWidth="180" />
                                <TableColumn fx:id="colInvoiceAmount" text="Amount" minWidth="120" />
                                <TableColumn fx:id="colInvoiceDue" text="Due Date" minWidth="120" />
                                <TableColumn fx:id="colInvoiceStatus" text="Status" minWidth="110" />
                            </columns>
                            <placeholder>
                                <Label text="No recent invoices to display."
                                    styleClass="table-placeholder" />
                            </placeholder>
                        </TableView>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
