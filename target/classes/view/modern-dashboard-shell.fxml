<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml"
    styleClass="banking-root"
    prefWidth="1320"
    prefHeight="840">

    <left>
        <VBox styleClass="sidebar" prefWidth="250" minWidth="250" maxWidth="250">
            <padding>
                <Insets top="24" right="16" bottom="20" left="16" />
            </padding>

            <VBox spacing="2">
                <Label text="CHEQUEPRINT PRO" styleClass="brand-title"/>
                <Label text="Banking Operations" styleClass="brand-subtitle"/>
            </VBox>

            <Region minHeight="24"/>

            <Label text="MENU" styleClass="menu-section"/>
            <Button text="Dashboard" styleClass="menu-button menu-button-active"/>
            <Button text="Cheque" styleClass="menu-button"/>
            <Button text="Reports" styleClass="menu-button"/>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox styleClass="sidebar-footer" spacing="2">
                <Label text="Signed in as" styleClass="footer-label"/>
                <Label text="Admin User" styleClass="footer-user"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox styleClass="main-panel">
            <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="14">
                <Label text="Dashboard" styleClass="topbar-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField promptText="Search cheque number, payee..." styleClass="search-field"/>
                <Button text="New Cheque" styleClass="btn btn-primary"/>
            </HBox>

            <VBox styleClass="content-wrap" spacing="18" VBox.vgrow="ALWAYS">
                <HBox spacing="18">
                    <VBox styleClass="card stat-card" HBox.hgrow="ALWAYS" spacing="6">
                        <Label text="Total Cheques" styleClass="stat-label"/>
                        <Label text="1,248" styleClass="stat-value"/>
                        <Label text="+6.2% this month" styleClass="stat-trend-positive"/>
                    </VBox>
                    <VBox styleClass="card stat-card" HBox.hgrow="ALWAYS" spacing="6">
                        <Label text="Pending Approval" styleClass="stat-label"/>
                        <Label text="34" styleClass="stat-value"/>
                        <Label text="Needs review today" styleClass="stat-trend-neutral"/>
                    </VBox>
                    <VBox styleClass="card stat-card" HBox.hgrow="ALWAYS" spacing="6">
                        <Label text="Printed Today" styleClass="stat-label"/>
                        <Label text="192" styleClass="stat-value"/>
                        <Label text="+18 from yesterday" styleClass="stat-trend-positive"/>
                    </VBox>
                </HBox>

                <HBox spacing="18" VBox.vgrow="ALWAYS">
                    <VBox styleClass="card" spacing="14" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                        <Label text="Recent Activity" styleClass="card-title"/>
                        <StackPane styleClass="table-placeholder" VBox.vgrow="ALWAYS">
                            <Label text="Place your TableView here"/>
                        </StackPane>
                    </VBox>

                    <VBox styleClass="card" spacing="12" prefWidth="320" minWidth="300" maxWidth="360">
                        <Label text="Quick Actions" styleClass="card-title"/>
                        <Button text="Print Selected Cheque" styleClass="btn btn-primary"/>
                        <Button text="Open Preview" styleClass="btn btn-secondary"/>
                        <Button text="Export Daily Report" styleClass="btn btn-secondary"/>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>
    </center>

</BorderPane>
