<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.chequeprint.controller.InvoiceController"
      fx:id="rootPane"
      styleClass="page-root"
      spacing="0">

    <VBox spacing="20" style="-fx-padding: 24 24 24 24;" VBox.vgrow="ALWAYS">

        <!-- Page Header -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="🧾 Invoice Management" styleClass="page-title"/>
                <Label text="Create and export professional invoices" styleClass="page-subtitle"/>
            </VBox>
            <Button text="+ New Invoice" styleClass="btn-primary" onAction="#onClear"/>
        </HBox>

        <!-- Filter Bar -->
        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="card"
              style="-fx-padding: 14 18 14 18;">
            <Label text="🔍" style="-fx-font-size:14px; -fx-text-fill:#94a3b8;"/>
            <TextField fx:id="searchField" promptText="Search by client or invoice no…"
                       styleClass="filter-input" prefWidth="280"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- Main Content: Table + Form -->
        <HBox spacing="20" VBox.vgrow="ALWAYS">

            <!-- Table -->
            <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="14">
                <Label text="All Invoices" styleClass="section-title"/>
                <TableView fx:id="invoiceTable" styleClass="data-table" VBox.vgrow="ALWAYS">
                    <placeholder>
                        <Label text="No invoices found. Click '+ New Invoice' to create one."
                               styleClass="table-placeholder"/>
                    </placeholder>
                    <columns>
                        <TableColumn fx:id="colInvoiceNo"  text="INVOICE NO"   prefWidth="120"/>
                        <TableColumn fx:id="colClient"     text="CLIENT"        prefWidth="170"/>
                        <TableColumn fx:id="colAmount"     text="AMOUNT"        prefWidth="120"/>
                        <TableColumn fx:id="colIssueDate"  text="ISSUE DATE"    prefWidth="110"/>
                        <TableColumn fx:id="colDueDate"    text="DUE DATE"      prefWidth="110"/>
                        <TableColumn fx:id="colStatus"     text="STATUS"        prefWidth="100"/>
                    </columns>
                </TableView>

                <!-- Actions -->
                <HBox spacing="10">
                    <Button text="📄  Export PDF" styleClass="btn-primary"   onAction="#onExportPdf"/>
                    <Button text="🗑  Delete"      styleClass="btn-danger"    onAction="#onDelete"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Click a row to edit" style="-fx-text-fill:#94a3b8; -fx-font-size:12px;" alignment="CENTER_RIGHT"/>
                </HBox>
            </VBox>

            <!-- Form Panel -->
            <VBox styleClass="card form-panel" spacing="16" minWidth="300" maxWidth="320">
                <Label fx:id="lblFormTitle" text="New Invoice" styleClass="form-title" maxWidth="Infinity"/>

                <VBox spacing="6">
                    <Label text="CLIENT NAME" styleClass="form-label"/>
                    <TextField fx:id="fldClient" promptText="Enter client name"
                               styleClass="form-input"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="AMOUNT (₹)" styleClass="form-label"/>
                    <TextField fx:id="fldAmount" promptText="0.00"
                               styleClass="form-input"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="ISSUE DATE" styleClass="form-label"/>
                    <DatePicker fx:id="dateIssue" styleClass="form-date" maxWidth="Infinity"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="DUE DATE" styleClass="form-label"/>
                    <DatePicker fx:id="dateDue" styleClass="form-date" maxWidth="Infinity"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="NOTES" styleClass="form-label"/>
                    <TextArea fx:id="fldNotes" promptText="Optional notes…"
                              styleClass="form-input" prefRowCount="3" wrapText="true"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <VBox spacing="8">
                    <Button text="💾  Save Invoice"  styleClass="btn-primary"
                            maxWidth="Infinity" onAction="#onSave"/>
                    <Button text="✕  Clear Form"     styleClass="btn-secondary"
                            maxWidth="Infinity" onAction="#onClear"/>
                </VBox>
            </VBox>
        </HBox>
    </VBox>
</VBox>