<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!--
  FIXED main.fxml
  ================
  ROOT ISSUE: BorderPane must fill the entire Scene. JavaFX BorderPane does NOT
  automatically stretch to fill the Scene unless prefWidth/prefHeight are
  explicitly bound to the Scene. The fix is to set both prefWidth and prefHeight
  to -1 (USE_COMPUTED_SIZE) on the BorderPane and let the Scene drive the size,
  combined with setting the scene to maximised in LoginController.

  KEY FIXES:
  1. BorderPane: removed maxWidth/maxHeight="Infinity" (no effect on root node).
     Added prefWidth="1280" prefHeight="800" as sensible startup defaults.
  2. Center VBox: must use VBox.vgrow="ALWAYS" or grow constraints to fill.
     Replaced plain VBox with proper fx:id binding and grow policies.
  3. StackPane contentPane: must have VBox.vgrow="ALWAYS" so it takes all
     remaining vertical space after the fixed-height header bar.
  4. Nav items: added fx:id attributes (navDashboard etc.) so MainController
     @FXML injection actually resolves — without these the controller crashes
     silently and nav styling breaks.
  5. Sidebar user footer: styled with proper styleClass for CSS.
-->
<BorderPane xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="com.chequeprint.controller.MainController"
    prefWidth="1280" prefHeight="800"
    minWidth="1000" minHeight="600"
    styleClass="app-root">

    <!-- ═══════════════════════════════════════
         LEFT SIDEBAR  (fixed 224 px wide)
    ═══════════════════════════════════════ -->
    <left>
        <VBox fx:id="sidebar" styleClass="sidebar"
            prefWidth="224" minWidth="224" maxWidth="224"
            prefHeight="800">

            <!-- Logo -->
            <VBox styleClass="sidebar-logo" spacing="2">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="💼" styleClass="sidebar-logo-icon" mouseTransparent="true" />
                    <VBox spacing="0" mouseTransparent="true">
                        <Label fx:id="sidebarLogoText" text="ChequePro" styleClass="sidebar-logo-text" />
                        <Label text="Finance Manager" styleClass="sidebar-logo-sub" />
                    </VBox>
                </HBox>
            </VBox>

            <!-- Navigation — VBox.vgrow="ALWAYS" so it stretches -->
            <VBox spacing="2" VBox.vgrow="ALWAYS" style="-fx-padding: 12 8 8 8;">

                <Label text="MAIN MENU" styleClass="sidebar-section-label" />

                <HBox fx:id="navDashboard" styleClass="nav-item" spacing="12"
                    alignment="CENTER_LEFT" onMouseClicked="#onDashboard" pickOnBounds="true">
                    <Label text="📊" styleClass="nav-icon" mouseTransparent="true" />
                    <Label text="Dashboard" styleClass="nav-label" mouseTransparent="true" />
                </HBox>

                <HBox fx:id="navCheques" styleClass="nav-item" spacing="12"
                    alignment="CENTER_LEFT" onMouseClicked="#onCheques" pickOnBounds="true">
                    <Label text="📝" styleClass="nav-icon" mouseTransparent="true" />
                    <Label text="Cheques" styleClass="nav-label" mouseTransparent="true" />
                </HBox>

                <HBox fx:id="navChequeHistory" styleClass="nav-item" spacing="12"
                    alignment="CENTER_LEFT" onMouseClicked="#onChequeHistory" pickOnBounds="true">
                    <Label text="📜" styleClass="nav-icon" mouseTransparent="true" />
                    <Label text="Cheque History" styleClass="nav-label" mouseTransparent="true" />
                </HBox>

                <HBox fx:id="navInvoices" styleClass="nav-item" spacing="12"
                    alignment="CENTER_LEFT" onMouseClicked="#onInvoices" pickOnBounds="true">
                    <Label text="🧾" styleClass="nav-icon" mouseTransparent="true" />
                    <Label text="Invoices" styleClass="nav-label" mouseTransparent="true" />
                </HBox>

                <HBox fx:id="navBanks" styleClass="nav-item" spacing="12"
                    alignment="CENTER_LEFT" onMouseClicked="#onBanks" pickOnBounds="true">
                    <Label text="🏦" styleClass="nav-icon" mouseTransparent="true" />
                    <Label text="Banks" styleClass="nav-label" mouseTransparent="true" />
                </HBox>

                <HBox fx:id="navAiAssistant" styleClass="nav-item" spacing="12"
                    alignment="CENTER_LEFT" onMouseClicked="#onAiAssistant" pickOnBounds="true">
                    <Label text="AI" styleClass="nav-icon" mouseTransparent="true" />
                    <Label text="AI Assistant" styleClass="nav-label" mouseTransparent="true" />
                </HBox>

                <Label text="ACCOUNT" styleClass="sidebar-section-label" />

                <HBox fx:id="navProfile" styleClass="nav-item" spacing="12"
                    alignment="CENTER_LEFT" onMouseClicked="#onProfile" pickOnBounds="true">
                    <Label text="👤" styleClass="nav-icon" mouseTransparent="true" />
                    <Label text="Profile" styleClass="nav-label" mouseTransparent="true" />
                </HBox>

                <HBox fx:id="navSettings" styleClass="nav-item" spacing="12"
                    alignment="CENTER_LEFT" onMouseClicked="#onSettings" pickOnBounds="true">
                    <Label text="⚙️" styleClass="nav-icon" mouseTransparent="true" />
                    <Label text="Settings" styleClass="nav-label" mouseTransparent="true" />
                </HBox>

                <HBox fx:id="navSupport" styleClass="nav-item" spacing="12"
                    alignment="CENTER_LEFT" onMouseClicked="#onSupport" pickOnBounds="true">
                    <Label text="💬" styleClass="nav-icon" mouseTransparent="true" />
                    <Label text="Support" styleClass="nav-label" mouseTransparent="true" />
                </HBox>

                <!-- Spacer pushes user footer to bottom -->
                <Region VBox.vgrow="ALWAYS" />

                <!-- User footer -->
                <HBox fx:id="userFooter" spacing="10" alignment="CENTER_LEFT" styleClass="sidebar-user">
                    <Label fx:id="lblUserAvatar" text="AD" styleClass="user-avatar" />
                    <VBox spacing="1">
                        <Label fx:id="lblUserName" text="Admin User" styleClass="user-name" />
                        <Label fx:id="lblUserRole" text="Administrator" styleClass="user-role" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button fx:id="btnLogout" text="Logout" styleClass="btn-ghost" onAction="#onLogout" />
                </HBox>

            </VBox>
        </VBox>
    </left>

    <!-- ═══════════════════════════════════════
         CENTER  (header + dynamic content)
    ═══════════════════════════════════════ -->
    <center>
        <!--
          FIX: This VBox is the direct child of BorderPane center — it
          automatically fills all available width AND height because BorderPane
          gives its center region all remaining space. No maxWidth/maxHeight
          needed here; they were misleadingly added before but did nothing
          because BorderPane center is already unbounded.
        -->
        <VBox>

            <!-- TOP HEADER (fixed height via CSS: 58px) -->
            <HBox spacing="16" alignment="CENTER_LEFT" styleClass="top-header"
                prefHeight="58" minHeight="58" maxHeight="58"
                VBox.vgrow="NEVER"
                prefWidth="Infinity"
                maxWidth="Infinity">
                <Label fx:id="headerTitle" text="Dashboard" styleClass="header-title" />
                <Region HBox.hgrow="ALWAYS" />
                <TextField fx:id="mainSearchField" promptText="Search…" prefWidth="200" styleClass="search-input" />
                <Label fx:id="lblNotification" text="🔔" styleClass="icon-btn" onMouseClicked="#onNotificationClicked" />
                <Label text="AD" styleClass="header-avatar" /> 
            </HBox>

            <!-- CONTENT PANE
                 FIX: VBox.vgrow="ALWAYS" is the critical attribute here.
                 Without it the StackPane takes only its minimum height (0 if
                 empty) and the entire content area appears blank or collapsed.
                 All sub-page roots must ALSO declare maxWidth/maxHeight=Infinity
                 so StackPane can size them to fill itself (StackPane sizes
                 children to its own size, but only if their max allows it).
            -->
            <StackPane fx:id="contentPane"
                VBox.vgrow="ALWAYS" />
        </VBox>
    </center>

</BorderPane>
