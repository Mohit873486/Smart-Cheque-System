<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.chequeprint.controller.LoginController"
           fx:id="rootPane"
           styleClass="login-root"
           maxWidth="Infinity" maxHeight="Infinity">

    <VBox spacing="24" alignment="CENTER" maxWidth="560" maxHeight="Infinity"
          style="-fx-padding:40 24 40 24;">

        <VBox alignment="CENTER" spacing="10">
            <Label text="Smart Cheque System" styleClass="login-title" />
            <Label text="AI-Powered Cheque Processing" styleClass="login-subtitle" />
        </VBox>

        <VBox styleClass="login-card" spacing="22" maxWidth="520" minWidth="340">
            <VBox spacing="8">
                <Label text="Welcome back" styleClass="card-heading" />
                <Label text="Sign in to access the cheque automation dashboard" styleClass="card-subtitle" wrapText="true" />
            </VBox>

            <VBox spacing="14">
                <VBox spacing="8">
                    <Label text="Username or Email" styleClass="form-label" />
                    <TextField fx:id="fldUsername"
                               promptText="Enter username or email"
                               styleClass="form-input"
                               maxWidth="Infinity" />
                </VBox>

                <VBox spacing="8">
                    <Label text="Password" styleClass="form-label" />
                    <StackPane>
                        <PasswordField fx:id="fldPassword"
                                       promptText="Enter password"
                                       styleClass="form-input"
                                       maxWidth="Infinity" />
                        <TextField fx:id="fldPasswordVisible"
                                   promptText="Enter password"
                                   styleClass="form-input"
                                   visible="false"
                                   managed="false"
                                   maxWidth="Infinity" />
                        <Button fx:id="btnTogglePassword"
                                text="Show"
                                styleClass="password-toggle"
                                onAction="#onTogglePassword"
                                StackPane.alignment="CENTER_RIGHT" />
                    </StackPane>
                </VBox>

                <VBox spacing="8">
                    <Label text="Role" styleClass="form-label" />
                    <ChoiceBox fx:id="choiceRole" styleClass="form-input" maxWidth="Infinity" />
                </VBox>

                <HBox spacing="14" alignment="CENTER_LEFT">
                    <CheckBox fx:id="chkRememberMe" text="Remember me" />
                    <Hyperlink fx:id="linkForgotPassword"
                               text="Forgot password?"
                               onAction="#onForgotPassword"
                               styleClass="link-button" />
                </HBox>

                <Label fx:id="lblError" text=""
                       styleClass="login-error"
                       visible="false"
                       wrapText="true"
                       maxWidth="Infinity" />

                <Button fx:id="btnLogin"
                        text="Login"
                        styleClass="btn-primary"
                        maxWidth="Infinity"
                        onAction="#onLogin" />

                <Label fx:id="lblAttempts" text="3 attempts remaining" styleClass="attempts-label" />
            </VBox>

            <Label fx:id="lblDbStatus" text="Checking database…"
                   styleClass="db-status"
                   wrapText="true" />
        </VBox>
    </VBox>
</StackPane>
