<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
  FIXED banks.fxml
  =================
  The original banks.fxml was the closest to correct, but had a critical subtle
  bug: the inner VBox (direct child of root VBox) had maxHeight="Infinity" set
  but was ALSO inside a VBox that is the root.  A VBox does NOT automatically
  give extra vertical space to children with maxHeight="Infinity" — you must
  ALSO declare VBox.vgrow="ALWAYS" on that child.  Without it the HBox content
  area got zero extra height and the table was tiny.

  FIXES:
  1. Root VBox and inner VBox both have maxWidth/maxHeight="Infinity".
  2. Inner VBox (content wrapper): VBox.vgrow="ALWAYS" added.
  3. TableView: CONSTRAINED_RESIZE_POLICY added for proper column sizing.
  4. Form panel: HBox.hgrow="NEVER" confirmed, maxHeight="Infinity" confirmed.
-->
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.chequeprint.controller.BankController"
      fx:id="rootPane"
      styleClass="page-root"
      maxWidth="Infinity"
      maxHeight="Infinity"
      spacing="0">

    <!-- FIX: VBox.vgrow="ALWAYS" is REQUIRED here so this child stretches -->
    <VBox spacing="20"
          VBox.vgrow="ALWAYS"
          maxWidth="Infinity" maxHeight="Infinity"
          style="-fx-padding:24 24 24 24; -fx-background-color:#f1f5f9;">

        <!-- Page Header -->
        <HBox alignment="CENTER_LEFT" spacing="12" maxWidth="Infinity">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="🏦 Bank Templates" styleClass="page-title"/>
                <Label text="Manage cheque layout templates for each bank"
                       styleClass="page-subtitle"/>
            </VBox>
        </HBox>

        <!-- Main content -->
        <HBox spacing="20" VBox.vgrow="ALWAYS" maxHeight="Infinity">

            <!-- Table Card -->
            <VBox styleClass="card"
                  HBox.hgrow="ALWAYS"
                  maxWidth="Infinity" maxHeight="Infinity"
                  spacing="14">

                <Label text="All Bank Templates" styleClass="section-title"/>

                <TableView fx:id="bankTable"
                           styleClass="data-table"
                           VBox.vgrow="ALWAYS"
                           maxHeight="Infinity">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                    <placeholder>
                        <Label text="No bank templates found. Add one using the form."
                               styleClass="table-placeholder"/>
                    </placeholder>
                    <columns>
                        <TableColumn fx:id="colBankName"   text="BANK NAME"   minWidth="140"/>
                        <TableColumn fx:id="colBankCode"   text="CODE"        minWidth="70"/>
                        <TableColumn fx:id="colChequeSize" text="CHEQUE SIZE" minWidth="100"/>
                        <TableColumn fx:id="colMicr"       text="MICR"        minWidth="60"/>
                    </columns>
                </TableView>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button text="🗑  Delete Selected" styleClass="btn-danger"
                            onAction="#onDelete"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Click a row to edit"
                           style="-fx-text-fill:#94a3b8;-fx-font-size:12px;"/>
                </HBox>
            </VBox>

            <!-- Form Panel -->
            <VBox styleClass="card"
                  minWidth="280" prefWidth="300" maxWidth="300"
                  maxHeight="Infinity"
                  HBox.hgrow="NEVER"
                  spacing="16">

                <Label fx:id="lblFormTitle" text="Add New Bank"
                       styleClass="form-title" maxWidth="Infinity"/>

                <VBox spacing="6">
                    <Label text="BANK NAME" styleClass="form-label"/>
                    <TextField fx:id="fldBankName" promptText="e.g. Punjab National Bank"
                               styleClass="form-input" maxWidth="Infinity"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="BANK CODE" styleClass="form-label"/>
                    <TextField fx:id="fldBankCode" promptText="e.g. PNB"
                               styleClass="form-input" maxWidth="Infinity"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="CHEQUE SIZE" styleClass="form-label"/>
                    <ComboBox fx:id="cmbChequeSize" styleClass="form-combo"
                              maxWidth="Infinity"/>
                </VBox>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <CheckBox fx:id="chkMicr" selected="true"/>
                    <Label text="MICR Enabled" styleClass="form-label"
                           style="-fx-padding:0;"/>
                </HBox>

                <Region VBox.vgrow="ALWAYS"/>

                <VBox spacing="8">
                    <Button fx:id="btnSave" text="+ Add Bank" styleClass="btn-primary"
                            maxWidth="Infinity" onAction="#onSave"/>
                    <Button text="✕  Clear Form" styleClass="btn-secondary"
                            maxWidth="Infinity" onAction="#onClear"/>
                </VBox>
            </VBox>
        </HBox>
    </VBox>
</VBox>
