<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.chequeprint.controller.BankController"
      fx:id="rootPane"
      styleClass="page-root"
      maxWidth="Infinity" maxHeight="Infinity"
      spacing="0">

    <VBox spacing="20"
          VBox.vgrow="ALWAYS"
          maxWidth="Infinity" maxHeight="Infinity"
          style="-fx-padding:24 24 24 24;-fx-background-color:#f1f5f9;">

        <!-- Page Header -->
        <HBox alignment="CENTER_LEFT" spacing="12" maxWidth="Infinity">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="🏦 Bank Templates" styleClass="page-title"/>
                <Label text="Manage cheque layout templates for each bank"
                       styleClass="page-subtitle"/>
            </VBox>
        </HBox>

        <!-- Main content: Table left, Form right -->
        <HBox spacing="20" VBox.vgrow="ALWAYS" maxWidth="Infinity" maxHeight="Infinity">

            <!-- TABLE CARD -->
            <VBox styleClass="card"
                  HBox.hgrow="ALWAYS" maxWidth="Infinity" maxHeight="Infinity"
                  spacing="14">
                <Label text="All Bank Templates" styleClass="section-title"/>

                <TableView fx:id="bankTable"
                           styleClass="data-table"
                           VBox.vgrow="ALWAYS"
                           maxWidth="Infinity" maxHeight="Infinity">
                    <placeholder>
                        <Label text="No bank templates found. Add one using the form."
                               styleClass="table-placeholder"/>
                    </placeholder>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colBankName"   text="BANK NAME"   minWidth="140" prefWidth="200"/>
                        <TableColumn fx:id="colBankCode"   text="CODE"        minWidth="70"  prefWidth="90"/>
                        <TableColumn fx:id="colChequeSize" text="CHEQUE SIZE" minWidth="100" prefWidth="130"/>
                        <TableColumn fx:id="colMicr"       text="MICR"        minWidth="60"  prefWidth="80"/>
                    </columns>
                </TableView>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button text="🗑  Delete Selected" styleClass="btn-danger"
                            onAction="#onDelete"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Click a row to edit"
                           style="-fx-text-fill:#94a3b8;-fx-font-size:12px;"/>
                </HBox>
            </VBox>

            <!-- FORM PANEL -->
            <VBox styleClass="card"
                  minWidth="300" prefWidth="300" maxWidth="300"
                  maxHeight="Infinity" HBox.hgrow="NEVER"
                  spacing="16">

                <Label fx:id="lblFormTitle" text="Add New Bank"
                       styleClass="form-title" maxWidth="Infinity"/>

                <VBox spacing="6">
                    <Label text="BANK NAME" styleClass="form-label"/>
                    <TextField fx:id="fldBankName" promptText="e.g. Punjab National Bank"
                               styleClass="form-input" maxWidth="Infinity"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="BANK CODE" styleClass="form-label"/>
                    <TextField fx:id="fldBankCode" promptText="e.g. PNB"
                               styleClass="form-input" maxWidth="Infinity"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="CHEQUE SIZE" styleClass="form-label"/>
                    <ComboBox fx:id="cmbChequeSize" styleClass="form-combo"
                              maxWidth="Infinity"/>
                </VBox>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <CheckBox fx:id="chkMicr" selected="true"
                              style="-fx-text-fill:#1e293b;"/>
                    <Label text="MICR Enabled" styleClass="form-label"
                           style="-fx-padding:0;"/>
                </HBox>

                <Region VBox.vgrow="ALWAYS"/>

                <VBox spacing="8">
                    <Button fx:id="btnSave" text="+ Add Bank" styleClass="btn-primary"
                            maxWidth="Infinity" onAction="#onSave"/>
                    <Button text="✕  Clear Form" styleClass="btn-secondary"
                            maxWidth="Infinity" onAction="#onClear"/>
                </VBox>
            </VBox>
        </HBox>
    </VBox>
</VBox>
